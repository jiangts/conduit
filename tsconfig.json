{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "rootDir": "."
  },
  "include": ["./**/*"],
  "exclude": ["node_modules", "plans", "dist"]
}
